{
  "name": "wecom-codex-gateway",
  "version": "0.1.0",
  "description": "A lightweight WeCom/Feishu gateway for Codex CLI with multi-agent memory workspaces.",
  "main": "dist/server.js",
  "scripts": {
    "test": "LOG_LEVEL=error vitest run",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "publish:workspace": "bash ./bin/publish-workspace.sh",
    "tmp:deploy": "cd /opt/gateway && npm run publish:workspace"
  },
  "keywords": [
    "wecom",
    "feishu",
    "codex",
    "gateway",
    "agent",
    "memory"
  ],
  "author": "bairui",
  "license": "ISC",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/baibairui/codex-gateway.git"
  },
  "bugs": {
    "url": "https://github.com/baibairui/codex-gateway/issues"
  },
  "homepage": "https://github.com/baibairui/codex-gateway#readme",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "strip-ansi": "^7.2.0",
    "xml2js": "^0.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/xml2js": "^0.4.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
